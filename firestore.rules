rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 菜單：所有人可讀寫（開發模式）
    match /menu/{document=**} {
      allow read, write: if true;
    }
    
    // 訂單：所有人可讀寫（開發模式）
    match /orders/{document=**} {
      allow read, write: if true;
    }
  }
}
